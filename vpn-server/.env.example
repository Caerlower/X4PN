# Algorand wallet that receives USDC payments
AVM_ADDRESS=

# x402 facilitator (GoPlausible hosted)
FACILITATOR_URL=https://facilitator.goplausible.xyz

# Server port (x402 API — client connects here)
PORT=4021

# boringtun peer registration API (internal, same host)
BORINGTUN_API_URL=http://localhost:8080

# Pricing: USDC per minute of VPN session (default $0.001/min)
PRICE_PER_MINUTE_USDC=0.001

# Default session length when client omits durationMinutes
DEFAULT_SESSION_MINUTES=5

# Allowed session range (minutes)
MIN_SESSION_MINUTES=1
MAX_SESSION_MINUTES=60

# /renew only allowed in the last N seconds before session expires
RENEW_WINDOW_SECONDS=30
